# Daily Bible Bingo → Instagram publishing.
# Copy to .env.local for local work; set the real values in Vercel → Project
# → Settings → Environment Variables. NEVER commit real values.

# ── Emergency pause switch ────────────────────────────────────────────────
# Automatic (cron) publishing only runs when this is exactly "true".
# Set to "false" (or remove) to pause the daily post instantly.
INSTAGRAM_AUTOPUBLISH_ENABLED=false

# ── Meta / Instagram credentials (see docs/DAILY-INSTAGRAM.md) ────────────
# The Instagram professional account's numeric ID.
INSTAGRAM_ACCOUNT_ID=
# Long-lived access token with content-publishing permission.
META_ACCESS_TOKEN=
# App credentials — used when generating/refreshing the token (not at publish
# time, but keep them here so the whole setup lives in one place).
META_APP_ID=
META_APP_SECRET=
# Graph API base. Default: https://graph.facebook.com/v23.0
# If the account is connected via "Instagram API with Instagram Login",
# use https://graph.instagram.com/v23.0 instead.
META_GRAPH_API_BASE=

# ── Scheduling ────────────────────────────────────────────────────────────
# Vercel Cron sends "Authorization: Bearer $CRON_SECRET" automatically when
# this is set. Any random long string.
CRON_SECRET=
# Optional America/Chicago hour gate (0-23). Leave EMPTY with the default
# once-daily cron in vercel.json; only set this if you switch to an hourly
# cron schedule (Vercel Pro) and want to pick the hour by env var.
INSTAGRAM_PUBLISH_HOUR=

# ── YouVersion Platform (optional enhanced Scripture reader) ──────────────
# App Key from platform.youversion.com → Developer Dashboard → your app.
# CrossHeartPray uses the official REST API (developers.youversion.com)
# server-side only: API routes send it as the X-YVP-App-Key header and the
# key NEVER reaches a browser bundle (no NEXT_PUBLIC_ prefix — that is
# deliberate; scriptureProvider.test.ts enforces it). Never commit a real
# value. The site reads Scripture from the local public-domain WEB Bible
# whenever this is absent; with the key, translations the application is
# genuinely licensed for become readable in-app too.
YVP_APP_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────
# Key for /admin/social?key=... and manual publish calls. Any random string.
SOCIAL_ADMIN_KEY=

# Public site origin used for the image URL Meta fetches and og tags.
# Defaults to https://crossheartpray.com — only override for testing.
SITE_BASE_URL=

# Optional hashtag override, comma-separated (defaults live in
# src/lib/dailyBibleBingo.ts → DAILY_BIBLE_BINGO_HASHTAGS).
SOCIAL_HASHTAGS=
